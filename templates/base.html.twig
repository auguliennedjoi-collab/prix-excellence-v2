<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Cour Suprême du Bénin{% endblock %}</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0/dist/css/adminlte.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root { --bs-primary: #1a7a1a; }
        .bg-primary, .btn-primary { background-color: #1a7a1a !important; border-color: #1a7a1a !important; }
        .text-primary { color: #1a7a1a !important; }
        .navbar-light { background-color: #FFD700 !important; }
    </style>
    {% block extra_css %}{% endblock %}
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
<div class="app-wrapper">

{% block body %}{% endblock %}

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0/dist/js/adminlte.min.js"></script>
{% block extra_js %}{% endblock %}
</body>
</html>
