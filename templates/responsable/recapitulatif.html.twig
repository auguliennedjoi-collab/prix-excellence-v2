<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Récapitulatif - Cour Suprême du Bénin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f4f4f4; display: flex; flex-direction: column; min-height: 100vh; }
        .navbar { background-color: #1a7a1a; }
        .navbar-brand, .nav-link { color: white !important; }
        .nav-link:hover { color: #FFD700 !important; }
        footer { background-color: #1a7a1a; color: white; padding: 15px; text-align: center; margin-top: auto; }
        .table tbody tr:nth-child(odd) td { background-color: #f1f3f5; }
        .table tbody tr:nth-child(even) td { background-color: #e7f1fb; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg px-4">
    <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('responsable_index') }}">
        <span class="fw-bold">Cour Suprême du Bénin — Responsable</span>
    </a>
    <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto gap-2">
            <li class="nav-item"><a class="nav-link" href="{{ path('responsable_index') }}"><i class="bi bi-speedometer2 me-1"></i>Tableau de bord</a></li>
            <li class="nav-item"><a class="nav-link active" href="{{ path('responsable_recapitulatif') }}"><i class="bi bi-clipboard-data me-1"></i>Récapitulatif</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-1"></i>Déconnexion</a></li>
        </ul>
    </div>
</nav>

<div class="container-fluid py-5 px-4 flex-grow-1">
    <h4 class="fw-bold mb-1" style="color:#1a7a1a;">
        <i class="bi bi-clipboard-data me-2"></i>Récapitulatif des candidatures
    </h4>
    <p class="text-muted mb-4">{{ total }} candidature(s) au total, toutes éditions confondues.</p>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead style="background-color:#1a7a1a; color:white;">
                    <tr>
                        <th class="p-3">#</th>
                        <th class="p-3">Édition</th>
                        <th class="p-3">Nom & Prénoms</th>
                        <th class="p-3">Code suivi</th>
                        <th class="p-3">Écrit</th>
                        <th class="p-3">Oral</th>
                        <th class="p-3">Note finale</th>
                        <th class="p-3">Statut demande</th>
                        <th class="p-3">Statut traitement</th>
                    </tr>
                </thead>
                <tbody>
                    {% for candidature in candidatures %}
                        <tr>
                            <td class="p-3">{{ loop.index }}</td>
                            <td class="p-3">{{ candidature.edition ? candidature.edition.annee : '—' }}</td>
                            <td class="p-3 text-uppercase">{{ candidature.candidat.nom }} {{ candidature.candidat.prenoms }}</td>
                            <td class="p-3"><span class="badge bg-dark">{{ candidature.codeSuivi ?: '—' }}</span></td>
                            <td class="p-3">{{ candidature.noteEcriteGenerale is not null ? candidature.noteEcriteGenerale ~ '/20' : '—' }}</td>
                            <td class="p-3">{{ candidature.noteOrale is not null ? candidature.noteOrale ~ '/20' : '—' }}</td>
                            <td class="p-3">
                                {% if candidature.note is not null %}
                                    <span class="badge bg-primary">{{ candidature.note }}/20</span>
                                {% else %}
                                    <span class="text-muted small">—</span>
                                {% endif %}
                            </td>
                            <td class="p-3">
                                <span class="badge bg-{{ candidature.statutDemande.getBadgeColor }}">{{ candidature.statutDemande.getLabel }}</span>
                            </td>
                            <td class="p-3">
                                {% if candidature.statutTraitement.value == 'laureat' %}
                                    <span class="badge" style="background-color:#FFD700; color:#1a7a1a;"><i class="bi bi-trophy-fill me-1"></i>Lauréat</span>
                                {% else %}
                                    <span class="text-muted small">{{ candidature.statutTraitement.getLabel ?? candidature.statutTraitement.value }}</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="9" class="text-center p-4 text-muted">Aucune candidature enregistrée.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<footer>
    <p class="mb-0">&copy; Cour Suprême du Bénin — Tous droits réservés</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>