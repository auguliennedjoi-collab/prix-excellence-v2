<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Espace Responsable - Cour Suprême du Bénin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f4f4f4; display: flex; flex-direction: column; min-height: 100vh; }
        .navbar { background-color: #1a7a1a; }
        .navbar-brand, .nav-link { color: white !important; }
        .nav-link:hover { color: #FFD700 !important; }
        footer { background-color: #1a7a1a; color: white; padding: 15px; text-align: center; margin-top: auto; }
        .stat-card { border-left: 5px solid; border-radius: 10px; }
        .laureat-row { background-color: #fff8e1; font-weight: bold; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg px-4">
    <a class="navbar-brand d-flex align-items-center gap-2" href="#">
        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQmzw3pT2HwvieFTj_nB4nWbEVwWQfkuSpfwMtV7dTLOi7Nm-Ga4-RDR6s&s=10" height="45" alt="Logo">
        <span class="fw-bold">Cour Suprême du Bénin</span>
    </a>
    <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto gap-2">
            <li class="nav-item"><a class="nav-link" href="{{ path('verificateur_index') }}"><i class="bi bi-speedometer2 me-1"></i>Tableau de bord</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-1"></i>Déconnexion</a></li>
        </ul>
    </div>
</nav>

{# ===== TOASTS NOTIFICATIONS ===== #}
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999;">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
        <div class="toast show align-items-center text-white bg-{{ type == 'error' ? 'danger' : type }} border-0 rounded-3 shadow mb-2" role="alert">
            <div class="d-flex">
                <div class="toast-body fs-6">{{ message }}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
        {% endfor %}
    {% endfor %}
</div>

<div class="container py-4 flex-grow-1">

    {# ===== STATISTIQUES ===== #}
    <h4 class="fw-bold mb-4" style="color:#1a7a1a;">
        <i class="bi bi-speedometer2 me-2"></i>Supervision du concours
    </h4>
    <div class="row g-3 mb-5">
        <div class="col-md-3">
            <div class="card stat-card shadow-sm p-3" style="border-color:#1a7a1a;">
                <div class="text-muted small">Total candidats</div>
                <div class="fs-3 fw-bold" style="color:#1a7a1a;">{{ total }}</div>
                <i class="bi bi-people-fill fs-4 text-muted"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card shadow-sm p-3" style="border-color:#FFD700;">
                <div class="text-muted small">En attente</div>
                <div class="fs-3 fw-bold" style="color:#b8860b;">{{ enAttente }}</div>
                <i class="bi bi-hourglass-split fs-4 text-muted"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card shadow-sm p-3" style="border-color:#28a745;">
                <div class="text-muted small">Validés</div>
                <div class="fs-3 fw-bold text-success">{{ valides }}</div>
                <i class="bi bi-check-circle-fill fs-4 text-muted"></i>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card shadow-sm p-3" style="border-color:red;">
                <div class="text-muted small">Rejetés</div>
                <div class="fs-3 fw-bold text-danger">{{ rejetes }}</div>
                <i class="bi bi-x-circle-fill fs-4 text-muted"></i>
            </div>
        </div>
    </div>

    {# ===== CLASSEMENT ===== #}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold" style="color:#1a7a1a;">
            <i class="bi bi-trophy me-2"></i>Classement des évaluations
        </h5>
        <a href="/responsable/recapitulatif" class="btn btn-outline-success btn-sm">
            <i class="bi bi-file-earmark-pdf me-1"></i>Générer récapitulatif
        </a>
    </div>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead style="background-color:#1a7a1a; color:white;">
                        <tr>
                            <th class="p-3">Rang</th>
                            <th class="p-3">Code Candidat</th>
                            <th class="p-3">Identité Candidat</th>
                            <th class="p-3">Note /20</th>
                            <th class="p-3">Statut Traitement</th>
                            <th class="p-3">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for candidature in candidatures %}
                        {# Modifié pour vérifier si la note est présente sur l'objet candidature #}
                        <tr class="{{ loop.first and candidature.note is not null ? 'laureat-row' : '' }}">
                            <td class="p-3">
                                {% if loop.first and candidature.note is not null %}
                                    🏆 1er
                                {% else %}
                                    {{ loop.index }}
                                {% endif %}
                            </td>
                            <td class="p-3">
                                <span class="badge bg-secondary">{{ candidature.codeSuivi|default('N/A') }}</span>
                            </td>
                            <td class="p-3">
                                {# Récupération via la relation avec l'entité Candidat/User liée #}
                                {% if candidature.candidat is defined and candidature.candidat is not null %}
                                    <span class="text-uppercase fw-bold">{{ candidature.candidat.nom }}</span> {{ candidature.candidat.prenoms }}
                                {% else %}
                                    <span class="text-muted">Inconnu</span>
                                {% endif %}
                            </td>
                            <td class="p-3">
                                {% if candidature.note is not null %}
                                    <span class="badge bg-success fs-6">{{ candidature.note }}/20</span>
                                {% else %}
                                    <span class="text-muted">Non noté</span>
                                {% endif %}
                            </td>
                            <td class="p-3">
                                {# Utilisation de la propriété statutTraitement ou statutDemande définie dans ton Enum #}
                                {% if candidature.statutTraitement is defined and candidature.statutTraitement.value == 'LAUREAT' %}
                                    <span class="badge p-2" style="background-color:#FFD700; color:#333;">🏆 Lauréat</span>
                                {% else %}
                                    <span class="badge bg-success p-2">{{ candidature.statutDemande.getLabel }}</span>
                                {% endif %}
                            </td>
                            <td class="p-3">
                                {% if loop.first and candidature.note is not null and (candidature.statutTraitement is not defined or candidature.statutTraitement.value != 'LAUREAT') %}
                                    <a href="{{ path('verificateur_proclamer', {'id': candidature.id}) }}"
                                       class="btn btn-warning btn-sm fw-bold"
                                       onclick="return confirm('Proclamer ce candidat lauréat ?')">
                                        <i class="bi bi-trophy me-1"></i>Proclamer lauréat
                                    </a>
                                {% elseif candidature.statutTraitement is defined and candidature.statutTraitement.value == 'LAUREAT' %}
                                    <span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> Proclamé</span>
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="6" class="text-center p-4 text-muted">Aucun candidat validé pour le moment.</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<footer>
    <p class="mb-0">&copy; Cour Suprême du Bénin — Tous droits réservés</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    setTimeout(() => {
        document.querySelectorAll('.toast').forEach(t => {
            t.style.transition = 'opacity 0.5s';
            t.style.opacity = '0';
            setTimeout(() => t.style.display = 'none', 500);
        });
    }, 4000);
</script>
</body>
</html>
