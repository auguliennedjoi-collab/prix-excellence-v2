<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dépouillement final - Cour Suprême du Bénin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f4f4f4; display: flex; flex-direction: column; min-height: 100vh; }
        .navbar { background-color: #1a7a1a; }
        .navbar-brand, .nav-link { color: white !important; }
        .nav-link:hover { color: #FFD700 !important; }
        footer { background-color: #1a7a1a; color: white; padding: 15px; text-align: center; margin-top: auto; }
        .rang-badge { width: 36px; height: 36px; border-radius: 50%; background: #1a7a1a; color: white; display: inline-flex; align-items: center; justify-content: center; font-weight: bold; }
        .rang-badge.or { background: #FFD700; color: #1a7a1a; }
        .laureat-row { background: #fff9e6 !important; }

        /* Tableau PV d'impression (format officiel) */
        .pv-title-primary { color: #0033cc; font-weight: 700; }
        .pv-title-secondary { color: #c00000; font-weight: 700; }
        .pv-table thead th {
            background-color: #6699cc;
            color: #000;
            font-weight: 700;
            text-align: center;
            vertical-align: middle;
            border: 1px solid #333;
        }
        .pv-table td {
            border: 1px solid #333;
            vertical-align: middle;
        }
        .pv-table tbody tr:nth-child(odd) { background-color: #dbe6f4; }
        .pv-table tbody tr:nth-child(even) { background-color: #eef3fa; }
        .pv-num { text-align: center; font-weight: 600; width: 15%; }
        .pv-rang { text-align: center; font-weight: 700; width: 15%; }

        @media print {
            .no-print { display: none !important; }
            body { background: white; }
            .card { box-shadow: none !important; border: 1px solid #ccc !important; }
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg px-4 no-print">
    <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('admin_index') }}">
        <span class="fw-bold">Cour Suprême du Bénin — Admin</span>
    </a>
    <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto gap-2">
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_candidats') }}"><i class="bi bi-folder me-1"></i>Dossiers</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_plagiat') }}"><i class="bi bi-shield-exclamation me-1"></i>Plagiat</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-1"></i>Déconnexion</a></li>
        </ul>
    </div>
</nav>

<div class="toast-container position-fixed top-0 end-0 p-3 no-print" style="z-index:9999;">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
        {% set badgeType = type == 'error' ? 'danger' : type %}
        <div class="toast show align-items-center text-white bg-{{ badgeType }} border-0 rounded-3 shadow mb-2" role="alert">
            <div class="d-flex">
                <div class="toast-body fs-6"><i class="bi bi-info-circle-fill me-2"></i>{{ message }}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
        {% endfor %}
    {% endfor %}
</div>

<div class="container py-5 flex-grow-1" style="max-width: 950px;">
    <div class="d-flex justify-content-between align-items-start mb-1 no-print">
        <h4 class="fw-bold" style="color:#1a7a1a;">
            <i class="bi bi-trophy-fill me-2"></i>Dépouillement final
        </h4>
        <button onclick="window.print()" class="btn btn-outline-success btn-sm">
            <i class="bi bi-printer me-1"></i>Imprimer le PV
        </button>
    </div>
    <p class="text-muted mb-4 no-print">
        Classement final des candidats, identités révélées. Déclarez ici le ou les lauréats officiels du prix.
    </p>

    {% if edition is null %}
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Aucun finaliste disponible pour le moment. Le processus de présélection et de vérification du plagiat doit d'abord être terminé.
        </div>
    {% else %}

        {# ============================================================ #}
        {# BLOC ÉCRAN : gestion interactive des lauréats (masqué à l'impression) #}
        {# ============================================================ #}
        {% if laureats is not empty %}
            <div class="card shadow border-0 rounded-4 mb-4 no-print">
                <div class="card-header fw-bold" style="background-color:#FFD700; color:#1a7a1a;">
                    <i class="bi bi-trophy-fill me-2"></i>Lauréat(s) du Prix d'Excellence
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Candidat</th>
                                <th>Note finale</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for candidature in laureats %}
                                <tr class="laureat-row">
                                    <td>
                                        <strong>{{ candidature.candidat.nom }} {{ candidature.candidat.prenoms }}</strong>
                                        <div class="small text-muted font-monospace">{{ candidature.codeSuivi }}</div>
                                    </td>
                                    <td><span class="badge bg-success">{{ candidature.note }}/20</span></td>
                                    <td class="text-end">
                                        <a href="{{ path('admin_annuler_laureat', {id: candidature.id}) }}"
                                           class="btn btn-sm btn-outline-secondary"
                                           onclick="return confirm('Annuler la déclaration de lauréat pour {{ candidature.candidat.prenoms }} {{ candidature.candidat.nom }} ?');">
                                            <i class="bi bi-arrow-counterclockwise me-1"></i>Annuler
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}

        <div class="card shadow border-0 rounded-4 no-print">
            <div class="card-header fw-bold" style="background-color:#1a7a1a; color:white;">
                <i class="bi bi-list-ol me-2"></i>Classement des finalistes ({{ finalistes|length }})
            </div>
            <div class="card-body p-0">
                {% if finalistes is empty %}
                    <p class="text-muted p-4 mb-0">Aucun finaliste actif pour le moment.</p>
                {% else %}
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Rang</th>
                                <th>Candidat</th>
                                <th>Écrit général</th>
                                <th>Oral général</th>
                                <th>Note finale</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for candidature in finalistes %}
                                <tr>
                                    <td>
                                        <span class="rang-badge {{ loop.index == 1 ? 'or' : '' }}">{{ loop.index }}</span>
                                    </td>
                                    <td>
                                        <strong>{{ candidature.candidat.nom }} {{ candidature.candidat.prenoms }}</strong>
                                        <div class="small text-muted font-monospace">{{ candidature.codeSuivi }}</div>
                                    </td>
                                    <td>{{ candidature.noteEcriteGenerale }}/20</td>
                                    <td>{{ candidature.noteOrale }}/20</td>
                                    <td><span class="badge bg-primary">{{ candidature.note }}/20</span></td>
                                    <td class="text-end">
                                        <a href="{{ path('admin_declarer_laureat', {id: candidature.id}) }}"
                                           class="btn btn-sm btn-warning"
                                           onclick="return confirm('Déclarer {{ candidature.candidat.prenoms }} {{ candidature.candidat.nom }} comme Lauréat(e) officiel(le) ?');">
                                            <i class="bi bi-trophy me-1"></i>Déclarer Lauréat
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
        </div>

        {# ============================================================ #}
        {# BLOC IMPRESSION : PV officiel au format demandé              #}
        {# Visible uniquement à l'impression (masqué à l'écran)         #}
        {# ============================================================ #}
               <div class="d-none d-print-block">
            <div class="text-center mb-4">
                <h3 class="pv-title-primary mb-1">Prix d'excellence</h3>
                <h4 class="pv-title-secondary mb-2">Droit-Justice-Paix de la Cour suprême du Bénin</h4>
                <h5 class="text-uppercase fw-bold">Résultats définitifs</h5>
            </div>

            <table class="table pv-table mb-4">
                <thead>
                    <tr>
                        <th class="pv-num">N° IDENTIFICATION</th>
                        <th>NOM &amp; PRENOMS</th>
                        <th class="pv-rang">RANG</th>
                    </tr>
                </thead>
                <tbody>
                    {% for ligne in classementImpression %}
                        <tr>
                            <td class="pv-num">
                                {% for item in ligne.candidatures %}
                                    {{ item.numero }}{{ not loop.last ? ' / ' : '' }}
                                {% endfor %}
                            </td>
                            <td>
                                {% for item in ligne.candidatures %}
                                    {{ item.candidature.candidat.nom }} {{ item.candidature.candidat.prenoms }}{{ not loop.last ? ' et ' : '' }}
                                {% endfor %}
                            </td>
                            <td class="pv-rang">{{ ligne.rangLabel }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>

            <div class="row mt-5">
                <div class="col-6 text-center">
                    <p class="mb-5">Les membres du Jury</p>
                    <p>_____________________</p>
                </div>
                <div class="col-6 text-center">
                    <p class="mb-5">Fait à Cotonou, le {{ "now"|date("d/m/Y") }}</p>
                </div>
            </div>
        </div>

    {% endif %}
</div>

<footer class="no-print">
    <p class="mb-0">&copy; Cour Suprême du Bénin — Tous droits réservés</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    setTimeout(() => {
        document.querySelectorAll('.toast').forEach(t => {
            t.style.transition = 'opacity 0.5s';
            t.style.opacity = '0';
            setTimeout(() => t.style.display = 'none', 500);
        });
    }, 4000);
</script>
</body>
</html>