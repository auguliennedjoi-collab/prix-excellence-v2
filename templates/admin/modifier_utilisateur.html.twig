<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modifier l'Utilisateur - Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f4f4f4; display: flex; flex-direction: column; min-height: 100vh; }
        .navbar { background-color: #1a7a1a; }
        .navbar-brand, .nav-link { color: white !important; }
        .nav-link:hover { color: #FFD700 !important; }
        .card-custom { border: none; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.06); background: #ffffff; }
        footer { background-color: #1a7a1a; color: white; text-align: center; padding: 15px; margin-top: auto; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg px-4">
    <a class="navbar-brand d-flex align-items-center gap-2" href="#">
        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQmzw3pT2HwvieFTj_nB4nWbEVwWQfkuSpfwMtV7dTLOi7Nm-Ga4-RDR6s&s=10" height="45" alt="Logo">
        <span class="fw-bold">Cour Suprême du Bénin</span>
    </a>
    <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto gap-2">
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_index') }}"><i class="bi bi-speedometer2 me-1"></i>Tableau de bord</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_candidats') }}"><i class="bi bi-folder-fill me-1"></i>Candidatures</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_utilisateurs') }}"><i class="bi bi-shield-lock-fill me-1"></i>Utilisateurs</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_parametres') }}"><i class="bi bi-gear me-1"></i>Paramètres</a></li>z
            <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-1"></i>Déconnexion</a></li>
        </ul>
    </div>
</nav>

<div class="container py-5 flex-grow-1">
    <div class="row justify-content-center">
        <div class="col-md-7">

            <div class="mb-4">
                <a href="{{ path('admin_utilisateurs') }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Retour à la liste
                </a>
            </div>

            <div class="card card-custom border-0 rounded-4 p-2">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-1" style="color:#1a7a1a;">
                        <i class="bi bi-pencil-square me-2"></i>Modifier l'Utilisateur
                    </h4>
                    <p class="text-muted small mb-4">Mise à jour du profil de <strong>{{ user.prenoms }} {{ user.nom }}</strong></p>

                    <form method="POST">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Nom de famille</label>
                                <input type="text" name="nom" class="form-control" value="{{ user.nom }}" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Prénoms</label>
                                <input type="text" name="prenoms" class="form-control" value="{{ user.prenoms }}" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Adresse Email</label>
                            <input type="email" name="email" class="form-control" value="{{ user.email }}" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Numéro de Téléphone</label>
                            <input type="text" name="telephone" class="form-control" value="{{ user.telephone }}" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Titre / Fonction officielle</label>
                            <input type="text" name="titre" class="form-control" value="{{ user.titre }}" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Niveau de privilèges / Rôle</label>
                            <select name="role" class="form-select" required>
                                <option value="ROLE_JURY" {% if 'ROLE_JURY' in user.roles %}selected{% endif %}>Membre du Jury (Évaluation & Lecture)</option>
                                <option value="ROLE_ADMIN" {% if 'ROLE_ADMIN' in user.roles %}selected{% endif %}>Administrateur Système (Contrôle total)</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Nouveau mot de passe <span class="text-muted fw-normal">(Optionnel)</span></label>
                            <input type="password" name="mot_de_passe" class="form-control" placeholder="Laissez vide pour ne pas modifier" minlength="8">
                        </div>

                        <div class="row g-2">
                            <div class="col-6">
                                <button type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow-sm">
                                    <i class="bi bi-check-circle me-2"></i>Enregistrer
                                </button>
                            </div>
                            <div class="col-6">
                                <a href="{{ path('admin_utilisateurs') }}" class="btn btn-outline-secondary btn-lg w-100">Annuler</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<footer>
    <p class="mb-0">&copy; Cour Suprême du Bénin — Tous droits réservés</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
