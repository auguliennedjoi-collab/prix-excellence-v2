<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestion du plagiat - Cour Suprême du Bénin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f4f4f4; display: flex; flex-direction: column; min-height: 100vh; }
        .navbar { background-color: #1a7a1a; }
        .navbar-brand, .nav-link { color: white !important; }
        .nav-link:hover { color: #FFD700 !important; }
        footer { background-color: #1a7a1a; color: white; padding: 15px; text-align: center; margin-top: auto; }
        .rang-badge { width: 32px; height: 32px; border-radius: 50%; background: #1a7a1a; color: white; display: inline-flex; align-items: center; justify-content: center; font-weight: bold; }
        .taux-input { max-width: 120px; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg px-4">
    <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('admin_index') }}">
        <span class="fw-bold">Cour Suprême du Bénin — Admin</span>
    </a>
    <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto gap-2">
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_candidats') }}"><i class="bi bi-folder me-1"></i>Dossiers</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_depouillement') }}"><i class="bi bi-trophy me-1"></i>Dépouillement</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-1"></i>Déconnexion</a></li>
        </ul>
    </div>
</nav>

<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999;">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
        {% set badgeType = type == 'error' ? 'danger' : type %}
        <div class="toast show align-items-center text-white bg-{{ badgeType }} border-0 rounded-3 shadow mb-2" role="alert">
            <div class="d-flex">
                <div class="toast-body fs-6"><i class="bi bi-info-circle-fill me-2"></i>{{ message }}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
        {% endfor %}
    {% endfor %}
</div>

<div class="container py-5 flex-grow-1" style="max-width: 950px;">
    <h4 class="fw-bold mb-1" style="color:#1a7a1a;">
        <i class="bi bi-shield-exclamation me-2"></i>La Gestion du plagiat — Finalistes
    </h4>
    <p class="text-muted mb-4">
        Renseignez le taux de plagiat constaté pour chaque finaliste. Une fois TOUS les taux saisis, lancez l'élimination automatique des candidats les plus suspects, jusqu'à obtenir 5 finalistes.
    </p>

    {% if edition is null %}
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Aucune présélection disponible pour le moment. Les jurys doivent d'abord terminer toutes les évaluations (écrit + oral).
        </div>
    {% else %}

      <div class="d-flex justify-content-end mb-3">
            <a href="{{ path('admin_plagiat_lancer_elimination') }}"
               class="btn btn-danger"
               onclick="return confirm('❌ Confirmer l\'élimination des candidats ayant le taux de plagiat le plus élevé ?');">
                <i class="bi bi-x-circle-fill me-2"></i> Lancer l'élimination
            </a>
        </div>

        {% if tousTauxSaisis %}
            <div class="alert alert-success">
                <i class="bi bi-check-circle-fill me-2"></i>
                Tous les taux de plagiat ont été saisis. Vous pouvez lancer l'élimination automatique.
            </div>
        {% elseif pool|length > 5 %}
            <div class="alert alert-info">
                <i class="bi bi-info-circle-fill me-2"></i>
                Renseignez le taux de plagiat de <strong>tous</strong> les candidats ci-dessous pour débloquer l'élimination automatique.
            </div>
        {% endif %}

        <div class="card shadow border-0 rounded-4 mb-4">
            <div class="card-header fw-bold" style="background-color:#1a7a1a; color:white;">
                <i class="bi bi-people-fill me-2"></i>Finalistes actifs ({{ pool|length }})
            </div>
            <div class="card-body p-0">
                {% if pool is empty %}
                    <p class="text-muted p-4 mb-0">Aucun finaliste actif pour le moment.</p>
                {% else %}
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Candidat</th>
                                <th>Note finale</th>
                                <th>Taux de plagiat</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for candidature in pool %}
                                <tr>
                                    <td><span class="rang-badge">{{ loop.index }}</span></td>
                                    <td>
                                        <strong>{{ candidature.candidat.nom }} {{ candidature.candidat.prenoms }}</strong>
                                        <div class="small text-muted font-monospace">{{ candidature.codeSuivi }}</div>
                                    </td>
                                    <td><span class="badge bg-success">{{ candidature.note }}/20</span></td>
                                    <td>
                                        <form method="post" action="{{ path('admin_plagiat_taux', {id: candidature.id}) }}" class="d-flex gap-2 align-items-center">
                                            <input type="number"
                                                   name="taux_plagiat"
                                                   class="form-control form-control-sm taux-input"
                                                   min="0" max="100" step="0.01"
                                                   value="{{ candidature.tauxPlagiat }}"
                                                   placeholder="%"
                                                   required>
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-save"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
        </div>

        {% if elimines is not empty %}
            <div class="card shadow border-0 rounded-4 mb-4">
                <div class="card-header fw-bold bg-danger text-white">
                    <i class="bi bi-x-octagon me-2"></i>Éliminés pour plagiat ({{ elimines|length }})
                </div>
                <div class="card-body p-0">
                    <table class="table mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Candidat</th>
                                <th>Note finale</th>
                                <th>Taux de plagiat</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for candidature in elimines %}
                                <tr class="table-danger">
                                    <td>{{ candidature.candidat.nom }} {{ candidature.candidat.prenoms }}</td>
                                    <td>{{ candidature.note }}/20</td>
                                    <td>{{ candidature.tauxPlagiat }}%</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}

    {% endif %}
</div>

<footer>
    <p class="mb-0">&copy; Cour Suprême du Bénin — Tous droits réservés</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    setTimeout(() => {
        document.querySelectorAll('.toast').forEach(t => {
            t.style.transition = 'opacity 0.5s';
            t.style.opacity = '0';
            setTimeout(() => t.style.display = 'none', 500);
        });
    }, 4000);
</script>
</body>
</html>