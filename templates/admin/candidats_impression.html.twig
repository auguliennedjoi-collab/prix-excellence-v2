<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Liste des candidatures - Impression</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; }

        .pv-title-primary { color: #0033cc; font-weight: 700; }
        .pv-title-secondary { color: #c00000; font-weight: 700; }

        .pv-table thead th {
            background-color: #6699cc;
            color: #000;
            font-weight: 700;
            text-align: center;
            vertical-align: middle;
            border: 1px solid #333;
        }
        .pv-table td {
            border: 1px solid #333;
            vertical-align: middle;
        }
        .pv-table tbody tr:nth-child(odd) { background-color: #dbe6f4; }
        .pv-table tbody tr:nth-child(even) { background-color: #eef3fa; }

        @media print {
            .no-print { display: none !important; }
            body { background: white; }
        }
    </style>
</head>
<body>

<div class="container py-4 no-print d-flex justify-content-between align-items-center">
    <a href="{{ path('admin_candidats') }}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Retour à la liste
    </a>
    <button onclick="window.print()" class="btn btn-success btn-sm">
        <i class="bi bi-printer me-1"></i>Imprimer
    </button>
</div>

<div class="container" style="max-width: 1100px;">
    <div class="text-center mb-4">
        <h3 class="pv-title-primary mb-1">Prix d'excellence</h3>
        <h4 class="pv-title-secondary mb-2">Droit-Justice-Paix de la Cour suprême du Bénin</h4>
        <h5 class="text-uppercase fw-bold">Liste des candidatures déposées</h5>
        <p class="text-muted">Total : {{ candidatures|length }} candidature{{ candidatures|length > 1 ? 's' : '' }}</p>
    </div>

    <table class="table pv-table mb-4">
        <thead>
            <tr>
                <th>#</th>
                <th>Code Suivi</th>
                <th>Nom</th>
                <th>Prénoms</th>
                <th>Téléphone</th>
                <th>Niveau d'étude</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            {% for candidature in candidatures %}
                <tr>
                    <td class="text-center">{{ loop.index }}</td>
                    <td class="text-center">{{ candidature.codeSuivi ?: '—' }}</td>
                    <td class="text-uppercase">{{ candidature.candidat.nom }}</td>
                    <td>{{ candidature.candidat.prenoms }}</td>
                    <td>{{ candidature.candidat.telephone }}</td>
                    <td>{{ candidature.candidat.niveauEtude }}</td>
                    <td>{{ candidature.statutDemande.getLabel }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center p-4">Aucune candidature enregistrée.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="row mt-5">
        <div class="col-6 text-center">
            <p class="mb-5">Le Responsable</p>
            <p>_____________________</p>
        </div>
        <div class="col-6 text-center">
            <p class="mb-5">Fait à Cotonou, le {{ "now"|date("d/m/Y") }}</p>
        </div>
    </div>
</div>

</body>
</html>