<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tableau de bord Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f4f4f4; display: flex; flex-direction: column; min-height: 100vh; }
        .navbar { background-color: #1a7a1a; }
        .navbar-brand, .nav-link { color: white !important; }
        .nav-link:hover { color: #FFD700 !important; }
        .card-stat { border: none; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); transition: transform 0.2s; }
        .card-stat:hover { transform: translateY(-5px); }
        footer { background-color: #1a7a1a; color: white; padding: 15px; text-align: center; margin-top: auto; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg px-4">
    <a class="navbar-brand d-flex align-items-center gap-2" href="#">
        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQmzw3pT2HwvieFTj_nB4nWbEVwWQfkuSpfwMtV7dTLOi7Nm-Ga4-RDR6s&s=10" height="45" alt="Logo">
        <span class="fw-bold">Cour Suprême du Bénin</span>
    </a>
    <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto gap-2">
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_index') }}"><i class="bi bi-speedometer2 me-1"></i>Tableau de bord</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_candidats') }}"><i class="bi bi-folder-fill me-1"></i>Candidatures</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_utilisateurs') }}"><i class="bi bi-shield-lock me-1"></i>Utilisateurs</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_parametres') }}"><i class="bi bi-gear me-1"></i>Paramètres</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_criteres') }}"><i class="bi bi-list-check me-1"></i>Critères</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-1"></i>Déconnexion</a></li>
        </ul>
    </div>
</nav>

<div class="container py-5 flex-grow-1">
    <h4 class="fw-bold mb-4" style="color:#1a7a1a;"><i class="bi bi-speedometer2 me-2"></i>Tableau de bord Administrateur</h4>

    {# ===== COMPTEURS STATISTIQUES ===== #}
<div class="row g-4">
    <div class="col-md-3">
        <a href="{{ path('admin_candidats') }}" class="text-decoration-none">
            <div class="card card-stat p-4 text-center">
                <div style="font-size:2.5rem; color:#1a7a1a;"><i class="bi bi-collection-fill"></i></div>
                <h2 class="fw-bold mt-2" style="color:#1a7a1a;">{{ total }}</h2>
                <p class="text-muted mb-0">Total candidatures</p>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('admin_candidats', {'statut': 'soumis'}) }}" class="text-decoration-none">
            <div class="card card-stat p-4 text-center">
                <div style="font-size:2.5rem; color:#FFD700;"><i class="bi bi-hourglass-split"></i></div>
                <h2 class="fw-bold mt-2" style="color:#FFD700;">{{ enAttente }}</h2>
                <p class="text-muted mb-0">En attente (Soumis)</p>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('admin_candidats', {'statut': 'valide'}) }}" class="text-decoration-none">
            <div class="card card-stat p-4 text-center">
                <div style="font-size:2.5rem; color:green;"><i class="bi bi-check-circle-fill"></i></div>
                <h2 class="fw-bold mt-2" style="color:green;">{{ valides }}</h2>
                <p class="text-muted mb-0">Validées administrativement</p>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('admin_candidats', {'statut': 'rejete'}) }}" class="text-decoration-none">
            <div class="card card-stat p-4 text-center">
                <div style="font-size:2.5rem; color:red;"><i class="bi bi-x-circle-fill"></i></div>
                <h2 class="fw-bold mt-2" style="color:red;">{{ rejetes }}</h2>
                <p class="text-muted mb-0">Rejetées / Non recevables</p>
            </div>
        </a>
    </div>
</div>

    {# ===== RACCOURCIS D'ACTIONS ===== #}
    <div class="mt-5 d-flex flex-wrap gap-2">
        <a href="{{ path('admin_candidats') }}" class="btn btn-success btn-lg">
            <i class="bi bi-folder-fill me-2"></i>Gérer les candidatures
        </a>
        <a href="{{ path('admin_utilisateurs') }}" class="btn btn-outline-success btn-lg">
            <i class="bi bi-people-fill me-2"></i>Gérer les utilisateurs
        </a>
        <a href="{{ path('admin_parametres') }}" class="btn btn-outline-secondary btn-lg">
            <i class="bi bi-gear me-2"></i>Paramètres de la page d'accueil
        </a>
    </div>
</div>

<footer>
    <p class="mb-0">&copy; Cour Suprême du Bénin — Tous droits réservés</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
