<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nouvel Utilisateur - Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f4f4f4; display: flex; flex-direction: column; min-height: 100vh; }
        .navbar { background-color: #1a7a1a; }
        .navbar-brand, .nav-link { color: white !important; }
        .nav-link:hover { color: #FFD700 !important; }
        footer { background-color: #1a7a1a; color: white; padding: 15px; text-align: center; margin-top: auto; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg px-4">
    <a class="navbar-brand d-flex align-items-center gap-2" href="/admin">
        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQmzw3pT2HwvieFTj_nB4nWbEVwWQfkuSpfwMtV7dTLOi7Nm-Ga4-RDR6s&s=10" height="45" alt="Logo">
        <span class="fw-bold">Cour Suprême du Bénin</span>
    </a>
    <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto gap-2">
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_index') }}"><i class="bi bi-speedometer2 me-1"></i>Tableau de bord</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_candidats') }}"><i class="bi bi-folder-fill me-1"></i>Candidatures</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('admin_utilisateurs') }}"><i class="bi bi-people-fill me-1"></i>Utilisateurs</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-1"></i>Déconnexion</a></li>
        </ul>
    </div>
</nav>

<div class="container py-5 flex-grow-1">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header text-white text-center py-3 rounded-top-4" style="background-color:#1a7a1a;">
                    <h4 class="mb-0"><i class="bi bi-person-plus-fill me-2"></i>Inscrire un Nouvel Utilisateur</h4>
                    <small class="text-white-50">Création d'un compte pour le Jury ou l'Administration</small>
                </div>
                <div class="card-body p-4">
                    <form method="post">

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Nom</label>
                                <input type="text" name="nom" class="form-control" placeholder="Ex: ALAO" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Prénoms</label>
                                <input type="text" name="prenoms" class="form-control" placeholder="Ex: Rouchdane" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Adresse Email académique / professionnelle</label>
                            <input type="email" name="email" class="form-control" placeholder="exemple@coursupreme.bj" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Numéro de Téléphone</label>
                            <input type="text" name="telephone" class="form-control" placeholder="Ex: +229 01XXXXXXXX" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Titre / Fonction officielle</label>
                            <input type="text" name="titre" class="form-control" placeholder="Ex: Enseignant-Chercheur, Magistrat, Greffier" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Rôle d'accès affecté</label>
                            <select name="role" class="form-select" required>
                                <option value="">-- Choisir un niveau de privilèges --</option>
                                <option value="ROLE_JURY">Membre du Jury (Évaluation & Consultation)</option>
                                <option value="ROLE_ADMIN">Administrateur Système (Gestion totale)</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Mot de passe initial</label>
                            <input type="password" name="mot_de_passe" class="form-control" minlength="8" placeholder="Minimum 8 caractères" required>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg fw-bold">
                                <i class="bi bi-shield-check me-2"></i>Créer le compte utilisateur
                            </button>
                            <a href="{{ path('admin_utilisateurs') }}" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<footer>
    <p class="mb-0">&copy; Cour Suprême du Bénin — Tous droits réservés</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
