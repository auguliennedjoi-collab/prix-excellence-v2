{% extends 'base.html.twig' %}

{% block title %}Changement de mot de passe - Cour suprême du Bénin{% endblock %}
{% block navbar %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root { --vert: #1a7a1a; --or: #FFD700; }

    /* Wrapper imperméable pour isoler et centrer horizontalement + verticalement */
    .page-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: #f4f4f4;
        display: flex;
        flex-direction: column;
        z-index: 9999;
        overflow-y: auto;
    }

    .card-custom { border: none; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); background: #ffffff; }
    .btn-green { background-color: var(--vert); color: white; border: none; font-weight: bold; border-radius: 30px; }
    .btn-green:hover { background-color: #135813; color: white; }
    .text-green { color: var(--vert); }
    .focus-ring:focus { border-color: var(--vert) !important; box-shadow: 0 0 0 0.25rem rgba(26, 122, 26, 0.25) !important; }

    .main-content {
        flex-grow: 1;
        display: flex;
        align-items: center; /* Centrage vertical */
        justify-content: center; /* Centrage horizontal */
        padding: 2rem 0;
    }
</style>

<div class="page-wrapper">

    {# ===== NAVBAR INSTITUTIONNELLE EN HAUT ===== #}
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm w-100 flex-shrink-0" style="background-color: var(--vert);">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="{{ path('app_home') }}">
                <i class="bi bi-balance2 me-2" style="color: var(--or);"></i>
                <strong>Cour suprême du Bénin</strong>
            </a>
            <a href="{{ path('app_home') }}" class="btn btn-sm btn-outline-light rounded-pill px-3">
                <i class="bi bi-house-door me-1"></i> Accueil
            </a>
        </div>
    </nav>

    {# ===== ZONE CENTRALE RIGUREUSEMENT CENTRÉE ===== #}
    <div class="main-content container">
        <div class="row w-100 justify-content-center m-0">
            <div class="col-12" style="max-width: 450px;">

                <div class="card card-custom p-2 mb-4">
                    <div class="card-body p-4">

                        <div class="text-center mb-4">
                            <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQmzw3pT2HwvieFTj_nB4nWbEVwWQfkuSpfwMtV7dTLOi7Nm-Ga4-RDR6s&s=10" height="55" alt="Logo" class="mb-3">
                            <h4 class="fw-bold text-green mb-1">Choisir un mot de passe</h4>
                            <p class="text-muted small mb-0">Pour des raisons de sécurité, vous devez définir un nouveau mot de passe avant de continuer.</p>
                        </div>

                        {{ form_start(form) }}

                            {# ===== ALERTE GLOBALE ERREUR ===== #}
                            {% if form.vars.submitted and not form.vars.valid %}
                                <div class="alert alert-danger d-flex align-items-center border-0 shadow-sm mb-4" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                                    <div class="small">Veuillez corriger les erreurs ci-dessous.</div>
                                </div>
                            {% endif %}

                            {# ===== NOUVEAU MOT DE PASSE ===== #}
                            <div class="mb-3" data-controller="password-toggle">
                                <label class="form-label fw-bold text-muted small mb-1" for="{{ form.plainPassword.first.vars.id }}">
                                    Nouveau mot de passe
                                </label>
                                <div class="input-group">
                                    {{ form_widget(form.plainPassword.first, {
                                        'attr': {
                                            'class': 'form-control border-end-0 focus-ring form-control-lg fs-6',
                                            'placeholder': '••••••••',
                                            'data-password-toggle-target': 'input',
                                            'autocomplete': 'new-password'
                                        }
                                    }) }}
                                    <button type="button"
                                            class="input-group-text bg-white border-start-0 text-muted"
                                            data-action="click->password-toggle#toggle"
                                            tabindex="-1"
                                            style="border-color: #dee2e6;">
                                        <i class="bi bi-eye" data-password-toggle-target="icon"></i>
                                    </button>
                                </div>
                                {% for error in form.plainPassword.first.vars.errors %}
                                    <div class="text-danger small mt-1"><i class="bi bi-x-circle me-1"></i>{{ error.message }}</div>
                                {% endfor %}
                                <div class="form-text text-muted" style="font-size: 0.75rem;">Au moins 8 caractères requis.</div>
                            </div>

                            {# ===== CONFIRMATION MOT DE PASSE ===== #}
                            <div class="mb-4">
                                <label class="form-label fw-bold text-muted small mb-1" for="{{ form.plainPassword.second.vars.id }}">
                                    Confirmer le mot de passe
                                </label>
                                {{ form_widget(form.plainPassword.second, {
                                    'attr': {
                                        'class': 'form-control focus-ring form-control-lg fs-6',
                                        'placeholder': '••••••••',
                                        'autocomplete': 'new-password'
                                    }
                                }) }}
                                {% for error in form.plainPassword.second.vars.errors %}
                                    <div class="text-danger small mt-1"><i class="bi bi-x-circle me-1"></i>{{ error.message }}</div>
                                {% endfor %}
                            </div>

                            {# ===== SOUUMISSION ===== #}
                            <div class="d-grid">
                                <button class="btn btn-green btn-lg shadow-sm fw-bold fs-6 py-2" type="submit">
                                    <i class="bi bi-shield-check me-2"></i>Valider et continuer
                                </button>
                            </div>

                        {{ form_end(form) }}

                    </div>
                </div>

                <p class="text-center text-muted small mb-0">Secrétariat général de la Cour suprême — République du Bénin</p>

            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}
