<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Évaluer une candidature - Cour Suprême du Bénin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f4f4f4; display: flex; flex-direction: column; min-height: 100vh; }
        .navbar { background-color: #1a7a1a; }
        .navbar-brand, .nav-link { color: white !important; }
        .nav-link:hover { color: #FFD700 !important; }
        footer { background-color: #1a7a1a; color: white; padding: 15px; text-align: center; margin-top: auto; }
        .critere-row label { font-weight: 600; color: #333; }
        .critere-row .max-badge { font-size: 12px; color: #1a7a1a; font-weight: bold; }
        #recap-box { background: #f0f9f0; border: 2px dashed #1a7a1a; border-radius: 12px; }
        #note-ecrite-affichee { font-size: 2rem; font-weight: bold; color: #1a7a1a; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg px-4">
    <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('jury_index') }}">
        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQmzw3pT2HwvieFTj_nB4nWbEVwWQfkuSpfwMtV7dTLOi7Nm-Ga4-RDR6s&s=10" height="45" alt="Logo">
        <span class="fw-bold">Cour Suprême du Bénin</span>
    </a>
    <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto gap-2">
            <li class="nav-item"><a class="nav-link" href="{{ path('jury_index') }}"><i class="bi bi-list-check me-1"></i>Candidatures</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-1"></i>Déconnexion</a></li>
        </ul>
    </div>
</nav>

<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999;">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
        {% set badgeType = type == 'error' ? 'danger' : type %}
        <div class="toast show align-items-center text-white bg-{{ badgeType }} border-0 rounded-3 shadow mb-2" role="alert">
            <div class="d-flex">
                <div class="toast-body fs-6"><i class="bi bi-info-circle-fill me-2"></i>{{ message }}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
        {% endfor %}
    {% endfor %}
</div>

<div class="container py-5 flex-grow-1" style="max-width: 800px;">
    <a href="{{ path('jury_index') }}" class="btn btn-link text-decoration-none mb-3 ps-0" style="color:#1a7a1a;">
        <i class="bi bi-arrow-left me-1"></i>Retour à la liste
    </a>

    <h4 class="fw-bold mb-1" style="color:#1a7a1a;">
        <i class="bi bi-clipboard-check me-2"></i>Évaluation écrite de la candidature
    </h4>
    <p class="text-muted mb-4">
        Dossier n°<strong>{{ numeroAnonyme ?? 'N/A' }}</strong> — Niveau d'étude : {{ candidature.candidat.niveauEtude ?? 'Non renseigné' }}
    </p>

    <div class="alert alert-info mb-4">
        <i class="bi bi-info-circle-fill me-2"></i>
        Vous notez ici uniquement les critères écrits. La note orale sera à saisir séparément, une fois que tous les jurys auront terminé la notation écrite de tous les dossiers.
    </div>

    <form method="post" id="form-evaluation">
        <div class="card shadow border-0 rounded-4 mb-4">
            <div class="card-header fw-bold" style="background-color:#1a7a1a; color:white;">
                <i class="bi bi-list-ol me-2"></i>Critères écrits (sur 20)
            </div>
            <div class="card-body">
                {% for critere in criteres %}
                    {% if critere.hasEnfants %}
                        <div class="mb-3 pb-2 border-bottom">
                            <label class="form-label mb-2 d-block">{{ critere.nom }}</label>
                            <div class="max-badge mb-2">Note maximale : {{ critere.noteMax }}</div>
                            {% for enfant in critere.enfants %}
                                {% set noteExistante = evaluation ? evaluation.getNoteForCritere(enfant) : null %}
                                <div class="row align-items-center mb-2 ps-3">
                                    <div class="col-md-8">
                                        <label class="form-label mb-0 fw-normal">— {{ enfant.nom }}</label>
                                        <div class="max-badge">Note maximale : {{ enfant.noteMax }}</div>
                                    </div>
                                    <div class="col-md-4">
                                        <input type="number"
                                               name="notes[{{ enfant.id }}]"
                                               class="form-control note-critere"
                                               data-max="{{ enfant.noteMax }}"
                                               min="0"
                                               max="{{ enfant.noteMax }}"
                                               step="0.01"
                                               value="{{ noteExistante }}"
                                               required>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        {% set noteExistante = evaluation ? evaluation.getNoteForCritere(critere) : null %}
                        <div class="row align-items-center critere-row mb-3 pb-3 border-bottom">
                            <div class="col-md-8">
                                <label class="form-label mb-0">{{ critere.nom }}</label>
                                <div class="max-badge">Note maximale : {{ critere.noteMax }}</div>
                            </div>
                            <div class="col-md-4">
                                <input type="number"
                                       name="notes[{{ critere.id }}]"
                                       class="form-control note-critere"
                                       data-max="{{ critere.noteMax }}"
                                       min="0"
                                       max="{{ critere.noteMax }}"
                                       step="0.01"
                                       value="{{ noteExistante }}"
                                       required>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        </div>

        <div id="recap-box" class="p-4 mb-4 text-center">
            <div class="text-muted small mb-1">Total des critères écrits (calcul en temps réel)</div>
            <div id="note-ecrite-affichee">--/20</div>
        </div>

        <button type="submit" class="btn btn-success btn-lg w-100">
            <i class="bi bi-check-circle me-2"></i>Valider les notes écrites
        </button>
    </form>
</div>

<footer>
    <p class="mb-0">&copy; Cour Suprême du Bénin — Tous droits réservés</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    setTimeout(() => {
        document.querySelectorAll('.toast').forEach(t => {
            t.style.transition = 'opacity 0.5s';
            t.style.opacity = '0';
            setTimeout(() => t.style.display = 'none', 500);
        });
    }, 4000);

    function calculerTotalEcrit() {
        let totalEcrit = 0;
        let ecritValide = true;

        document.querySelectorAll('.note-critere').forEach(input => {
            const val = parseFloat(input.value.replace(',', '.'));
            const max = parseFloat(input.dataset.max);
            if (isNaN(val) || val < 0 || val > max) {
                ecritValide = false;
            } else {
                totalEcrit += val;
            }
        });

        const affichage = document.getElementById('note-ecrite-affichee');

        if (!ecritValide) {
            affichage.textContent = '--/20';
            return;
        }

        affichage.textContent = totalEcrit.toFixed(2) + '/20';
    }

    document.querySelectorAll('.note-critere').forEach(input => {
        input.addEventListener('input', calculerTotalEcrit);
    });

    calculerTotalEcrit();
</script>
</body>
</html>