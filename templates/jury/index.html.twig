<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Espace Jury - Cour Suprême du Bénin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f4f4f4; display: flex; flex-direction: column; min-height: 100vh; }
        .navbar { background-color: #1a7a1a; }
        .navbar-brand, .nav-link { color: white !important; }
        .nav-link:hover { color: #FFD700 !important; }
        footer { background-color: #1a7a1a; color: white; padding: 15px; text-align: center; margin-top: auto; }
        .note-deja { font-size: 12px; color: #1a7a1a; font-weight: bold; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg px-4">
    <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('jury_index') }}">
        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQmzw3pT2HwvieFTj_nB4nWbEVwWQfkuSpfwMtV7dTLOi7Nm-Ga4-RDR6s&s=10" height="45" alt="Logo">
        <span class="fw-bold">Cour Suprême du Bénin</span>
    </a>
    <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto gap-2">
            <li class="nav-item"><a class="nav-link" href="{{ path('jury_index') }}"><i class="bi bi-list-check me-1"></i>Candidatures</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-1"></i>Déconnexion</a></li>
        </ul>
    </div>
</nav>

{# ===== TOASTS FLASH ===== #}
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999;">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
        {% set badgeType = type == 'error' ? 'danger' : type %}
        <div class="toast show align-items-center text-white bg-{{ badgeType }} border-0 rounded-3 shadow mb-2" role="alert">
            <div class="d-flex">
                <div class="toast-body fs-6"><i class="bi bi-info-circle-fill me-2"></i>{{ message }}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
        {% endfor %}
    {% endfor %}
</div>

<div class="container py-5 flex-grow-1">
    <h4 class="fw-bold mb-2" style="color:#1a7a1a;">
        <i class="bi bi-shield-lock me-2"></i>Évaluation anonyme des candidatures
    </h4>
    <p class="text-muted mb-4">Seules les candidatures validées administrativement sont visibles. Les identités des candidats restent masquées.</p>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead style="background-color:#1a7a1a; color:white;">
                    <tr>
                        <th class="p-3">#</th>
                        <th class="p-3">Niveau d'étude</th>
                        <th class="p-3">Documents joints</th>
                        <th class="p-3">Évaluation</th>
                    </tr>
                </thead>
                <tbody>
                    {% set found = false %}
                    {% set counter = 0 %}

                    {% for candidature in candidatures %}
                        {% if candidature.statutDemande.value == 'valide' %}
                            {% set found = true %}
                            {% set counter = counter + 1 %}
                             {% set monEvaluation = evaluationsParCandidature[candidature.id] ?? null %}
                            {% set docsMasques = ['identityFile', 'diplomaFile', 'cvFile'] %}
                            {% set docsVisibles = candidature.document|filter(doc => doc.type not in docsMasques) %}
                            <tr>
                                <td class="p-3 align-middle">{{ counter }}</td>
                                <td class="p-3 align-middle">
                                    {{ candidature.candidat.niveauEtude ?? 'Non renseigné' }}
                                </td>
                                <td class="p-3 align-middle">
                                    <div class="d-flex gap-2">
                                        {% for doc in docsVisibles %}
                                            <a href="{{ asset(doc.chemin) }}" target="_blank" class="btn btn-outline-success btn-sm" title="{{ doc.type ?? 'Pièce' }}">
                                                <i class="bi bi-file-earmark-pdf me-1"></i>{{ doc.type ?? 'Pièce' }}
                                            </a>
                                        {% else %}
                                            <span class="text-muted small">Aucune pièce disponible</span>
                                        {% endfor %}
                                    </div>
                                </td>
                                <td class="p-3 align-middle">
                                    {% if monEvaluation %}
                                        <div class="note-deja mb-1">
                                            <i class="bi bi-check-circle-fill text-success"></i> Déjà noté : {{ monEvaluation.noteFinale }}/20
                                        </div>
                                        <a href="{{ path('jury_noter', {'id': candidature.id}) }}" class="btn btn-outline-success btn-sm">
                                            <i class="bi bi-pencil-square me-1"></i>Modifier ma note
                                        </a>
                                    {% else %}
                                        <a href="{{ path('jury_noter', {'id': candidature.id}) }}" class="btn btn-success btn-sm">
                                            <i class="bi bi-pencil-square me-1"></i>Évaluer
                                        </a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endif %}
                    {% else %}
                        {% set found = false %}
                    {% endfor %}

                    {% if not found %}
                    <tr>
                        <td colspan="4" class="text-center p-4 text-muted">Aucune candidature validée disponible pour évaluation.</td>
                    </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<footer>
    <p class="mb-0">&copy; Cour Suprême du Bénin — Tous droits réservés</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    setTimeout(() => {
        document.querySelectorAll('.toast').forEach(t => {
            t.style.transition = 'opacity 0.5s';
            t.style.opacity = '0';
            setTimeout(() => t.style.display = 'none', 500);
        });
    }, 4000);
</script>
</body>
</html>