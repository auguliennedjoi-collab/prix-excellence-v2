<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Note orale - Cour Suprême du Bénin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f4f4f4; display: flex; flex-direction: column; min-height: 100vh; }
        .navbar { background-color: #1a7a1a; }
        .navbar-brand, .nav-link { color: white !important; }
        .nav-link:hover { color: #FFD700 !important; }
        footer { background-color: #1a7a1a; color: white; padding: 15px; text-align: center; margin-top: auto; }
        #recap-box { background: #f0f9f0; border: 2px dashed #1a7a1a; border-radius: 12px; }
        #note-finale-affichee { font-size: 2rem; font-weight: bold; color: #1a7a1a; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg px-4">
    <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('jury_index') }}">
        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQmzw3pT2HwvieFTj_nB4nWbEVwWQfkuSpfwMtV7dTLOi7Nm-Ga4-RDR6s&s=10" height="45" alt="Logo">
        <span class="fw-bold">Cour Suprême du Bénin</span>
    </a>
    <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto gap-2">
            <li class="nav-item"><a class="nav-link" href="{{ path('jury_index') }}"><i class="bi bi-list-check me-1"></i>Candidatures</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-1"></i>Déconnexion</a></li>
        </ul>
    </div>
</nav>

<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999;">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
        {% set badgeType = type == 'error' ? 'danger' : type %}
        <div class="toast show align-items-center text-white bg-{{ badgeType }} border-0 rounded-3 shadow mb-2" role="alert">
            <div class="d-flex">
                <div class="toast-body fs-6"><i class="bi bi-info-circle-fill me-2"></i>{{ message }}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
        {% endfor %}
    {% endfor %}
</div>

<div class="container py-5 flex-grow-1" style="max-width: 700px;">
    <a href="{{ path('jury_index') }}" class="btn btn-link text-decoration-none mb-3 ps-0" style="color:#1a7a1a;">
        <i class="bi bi-arrow-left me-1"></i>Retour à la liste
    </a>

    <h4 class="fw-bold mb-1" style="color:#1a7a1a;">
        <i class="bi bi-mic-fill me-2"></i>Note orale
    </h4>
    <p class="text-muted mb-4">
        Dossier n°<strong>{{ numeroAnonyme ?? 'N/A' }}</strong>
    </p>

    <div class="alert alert-success mb-4">
        <i class="bi bi-check-circle-fill me-2"></i>
        Note écrite générale (moyenne de tous les jurys) : <strong>{{ candidature.noteEcriteGenerale }}/20</strong>.
    </div>

    {% if dejaSaisie %}
        <div class="alert alert-info mb-4">
            <i class="bi bi-info-circle-fill me-2"></i>
            La note orale de ce candidat a déjà été saisie par un collègue jury : <strong>{{ candidature.noteOrale }}/20</strong>.
        </div>
        <div id="recap-box" class="p-4 mb-4 text-center">
            <div class="text-muted small mb-1">Note finale du candidat</div>
            <div id="note-finale-affichee">{{ candidature.note }}/20</div>
            <div class="small text-muted mt-1">
                (75% × note écrite générale + 25% × note orale)
            </div>
        </div>
    {% else %}
        <div class="alert alert-warning mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Cette note orale n'a pas encore été saisie. Une fois enregistrée, elle ne pourra plus être ressaisie par un autre jury.
        </div>

        <form method="post" id="form-oral">
            <div class="card shadow border-0 rounded-4 mb-4">
                <div class="card-header fw-bold" style="background-color:#1a7a1a; color:white;">
                    <i class="bi bi-mic me-2"></i>Note orale (sur 20)
                </div>
                <div class="card-body">
                    <input type="number"
                           name="note_orale"
                           id="note_orale"
                           class="form-control"
                           min="0"
                           max="20"
                           step="0.01"
                           required>
                </div>
            </div>

            <div id="recap-box" class="p-4 mb-4 text-center">
                <div class="text-muted small mb-1">Note finale estimée (calcul en temps réel)</div>
                <div id="note-finale-affichee">--/20</div>
                <div class="small text-muted mt-1">
                    (75% × note écrite générale + 25% × note orale)
                </div>
            </div>

            <button type="submit" class="btn btn-success btn-lg w-100">
                <i class="bi bi-check-circle me-2"></i>Enregistrer la note orale
            </button>
        </form>
    {% endif %}
</div>

<footer>
    <p class="mb-0">&copy; Cour Suprême du Bénin — Tous droits réservés</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    setTimeout(() => {
        document.querySelectorAll('.toast').forEach(t => {
            t.style.transition = 'opacity 0.5s';
            t.style.opacity = '0';
            setTimeout(() => t.style.display = 'none', 500);
        });
    }, 4000);

    {% if not dejaSaisie %}
    const noteEcriteGenerale = {{ candidature.noteEcriteGenerale ?? 0 }};

    function calculerNoteFinale() {
        const noteOraleInput = document.getElementById('note_orale');
        const noteOrale = parseFloat(noteOraleInput.value.replace(',', '.'));
        const affichage = document.getElementById('note-finale-affichee');

        if (isNaN(noteOrale) || noteOrale < 0 || noteOrale > 20) {
            affichage.textContent = '--/20';
            return;
        }

        const finale = (0.75 * noteEcriteGenerale) + (0.25 * noteOrale);
        affichage.textContent = finale.toFixed(2) + '/20';
    }

    document.getElementById('note_orale').addEventListener('input', calculerNoteFinale);
    calculerNoteFinale();
    {% endif %}
</script>
</body>
</html>